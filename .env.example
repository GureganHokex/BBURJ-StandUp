# Development (docker compose up)
APP_ENV=development
PORT=8080
DATABASE_URL=postgres://comic:comic@localhost:5432/comic?sslmode=disable
SESSION_SECRET=change-me-32-chars-minimum-secret-key-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SECURE_COOKIES=false
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
# MIGRATIONS_DIR=migrations

# Production checklist (APP_ENV=production):
# - SESSION_SECRET: openssl rand -hex 32 (min 32 chars, unique)
# - ADMIN_PASSWORD: min 12 chars, not admin123 (used only on first DB seed)
# - SECURE_COOKIES=true behind HTTPS reverse proxy
# - DATABASE_URL with sslmode=require
# - TRUSTED_PROXIES=IP of your nginx/caddy (for correct ClientIP + rate limits)
