# Yandex Cloud — single VM (copy to .env on the server, never commit .env)

# Домен с A-записью на публичный IP VM (нужен для HTTPS через Caddy)
DOMAIN=standup.example.ru

POSTGRES_USER=comic
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-16
POSTGRES_DB=comic

# sslmode=prefer — Postgres внутри Docker-сети, без публичного порта 5432
DATABASE_URL=postgres://comic:change-me-use-openssl-rand-hex-16@db:5432/comic?sslmode=prefer

# openssl rand -hex 32
SESSION_SECRET=

ADMIN_USERNAME=admin
# минимум 12 символов, не admin123
ADMIN_PASSWORD=

# Docker bridge — для корректного ClientIP за Caddy
TRUSTED_PROXIES=172.16.0.0/12
