# Example production stack. Copy to docker-compose.prod.yml and fill secrets via .env (never commit .env).
# Usage: docker compose -f docker-compose.prod.yml --env-file .env up -d

services:
  db:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB:-comic}
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB:-comic}"]
      interval: 10s
      timeout: 5s
      retries: 5
    # Do not publish Postgres to the internet
    expose:
      - "5432"

  app:
    build: .
    restart: unless-stopped
    expose:
      - "8080"
    environment:
      APP_ENV: production
      PORT: "8080"
      DATABASE_URL: ${DATABASE_URL}
      SESSION_SECRET: ${SESSION_SECRET}
      ADMIN_USERNAME: ${ADMIN_USERNAME}
      ADMIN_PASSWORD: ${ADMIN_PASSWORD}
      SECURE_COOKIES: "true"
      UPLOAD_DIR: /app/uploads
      MAX_UPLOAD_MB: "10"
      MIGRATIONS_DIR: /app/migrations
      TRUSTED_PROXIES: ${TRUSTED_PROXIES:-}
    volumes:
      - uploads:/app/uploads
    depends_on:
      db:
        condition: service_healthy

volumes:
  pgdata:
  uploads:
